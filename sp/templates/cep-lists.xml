  <pnp:Preferences Generator="PnP.Framework" />

  <pnp:Templates ID="CONTAINER-CEP">
    <pnp:ProvisioningTemplate ID="CEP-LISTS" Version="1" Scope="Web">

      <!-- ═══════════════════════════════════════════════════════
           SITE COLUMNS  (Group: "CEP Columns")
           ═══════════════════════════════════════════════════════ -->
      <pnp:SiteFields>

        <!-- ── CEP_Users ─────────────────────────────────────── -->
        <Field ID="{A1B2C3D4-0001-0001-0001-000000000001}"
               Name="CEP_UserEmail"         DisplayName="User Email"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="255" />

        <Field ID="{A1B2C3D4-0001-0001-0001-000000000002}"
               Name="CEP_UserPrincipalName" DisplayName="User Principal Name"
               Type="Text"                  Group="CEP Columns"

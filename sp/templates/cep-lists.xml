        <!-- ── CEP_Leaderboard ────────────────────────────────── -->
        <Field ID="{A1B2C3D4-0003-0003-0003-000000000001}"
               Name="CEP_LB_UserEmail"      DisplayName="User Email"
               Type="Text"                  Group="CEP Columns"

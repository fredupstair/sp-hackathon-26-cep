        <Field ID="{A1B2C3D4-0002-0002-0002-000000000004}"
               Name="CEP_Log_AppKey"        DisplayName="App"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown">
          <CHOICES>
            <CHOICE>Word</CHOICE>
            <CHOICE>Excel</CHOICE>
            <CHOICE>PowerPoint</CHOICE>
            <CHOICE>Outlook</CHOICE>
            <CHOICE>Teams</CHOICE>
            <CHOICE>OneNote</CHOICE>
            <CHOICE>Loop</CHOICE>
            <CHOICE>BizChat</CHOICE>
            <CHOICE>WebChat</CHOICE>
            <CHOICE>M365App</CHOICE>
            <CHOICE>Forms</CHOICE>
            <CHOICE>SharePoint</CHOICE>
            <CHOICE>Whiteboard</CHOICE>
            <CHOICE>Win</CHOICE>
          </CHOICES>
        </Field>

        <Field ID="{A1B2C3D4-0002-0002-0002-000000000005}"
               Name="CEP_Log_PromptCount"   DisplayName="Prompt Count"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

        <Field ID="{A1B2C3D4-0002-0002-0002-000000000006}"
               Name="CEP_Log_PointsEarned"  DisplayName="Points Earned"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

        <Field ID="{A1B2C3D4-0002-0002-0002-000000000007}"
               Name="CEP_Log_MonthKey"      DisplayName="Month Key"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="10" />
        <Field ID="{A1B2C3D4-0002-0002-0002-000000000008}"
               Name="CEP_Log_IsWin"         DisplayName="Is Win"
               Type="Boolean"               Group="CEP Columns">
          <Default>0</Default>

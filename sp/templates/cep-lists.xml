        <Field ID="{A1B2C3D4-0002-0002-0002-000000000009}"
               Name="CEP_Log_WinNote"       DisplayName="Win Note"
               Type="Text"                  Group="CEP Columns"
               MaxLength="140" />

        <Field ID="{A1B2C3D4-0002-0002-0002-000000000010}"
               Name="CEP_Log_IsShared"      DisplayName="Is Shared"
               Type="Boolean"               Group="CEP Columns">
          <Default>0</Default>
        </Field>

        <Field ID="{A1B2C3D4-0002-0002-0002-000000000011}"
               Name="CEP_Log_WinAppKey"     DisplayName="Win App Key"
               Type="Text"                  Group="CEP Columns"

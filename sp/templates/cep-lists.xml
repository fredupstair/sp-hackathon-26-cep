        <Field ID="{A1B2C3D4-0001-0001-0001-000000000008}"
               Name="CEP_TotalPoints"       DisplayName="Total Points"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

        <Field ID="{A1B2C3D4-0001-0001-0001-000000000009}"
               Name="CEP_MonthlyPoints"     DisplayName="Monthly Points"

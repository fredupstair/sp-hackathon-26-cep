        <Field ID="{A1B2C3D4-0001-0001-0001-000000000007}"
               Name="CEP_CurrentLevel"      DisplayName="Current Level"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown"            Default="Explorer">

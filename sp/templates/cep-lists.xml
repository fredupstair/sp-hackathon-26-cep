        <Field ID="{A1B2C3D4-0003-0003-0003-000000000002}"
               Name="CEP_LB_DisplayName"    DisplayName="Display Name"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000003}"
               Name="CEP_LB_Department"     DisplayName="Department"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000004}"
               Name="CEP_LB_Team"           DisplayName="Team"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000005}"
               Name="CEP_LB_AadUserId"      DisplayName="AAD User Id"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000006}"
               Name="CEP_LB_MonthlyPoints"  DisplayName="Monthly Points"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000007}"
               Name="CEP_LB_Rank"           DisplayName="Rank"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="1" />

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000008}"
               Name="CEP_LB_Level"          DisplayName="Level"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown">
          <CHOICES>
            <CHOICE>Explorer</CHOICE>
            <CHOICE>Practitioner</CHOICE>
            <CHOICE>Master</CHOICE>
          </CHOICES>
        </Field>

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000009}"
               Name="CEP_LB_Scope"          DisplayName="Scope"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown"            Indexed="TRUE">
          <CHOICES>
            <CHOICE>Global</CHOICE>
            <CHOICE>Department</CHOICE>
            <CHOICE>Team</CHOICE>
          </CHOICES>
        </Field>

        <Field ID="{A1B2C3D4-0003-0003-0003-000000000010}"
               Name="CEP_LB_MonthKey"       DisplayName="Month Key"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="10" />

        <!-- ── CEP_Badges ──────────────────────────────────────── -->
        <Field ID="{A1B2C3D4-0004-0004-0004-000000000001}"
               Name="CEP_Badge_UserEmail"   DisplayName="User Email"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000002}"
               Name="CEP_Badge_AadUserId"   DisplayName="AAD User Id"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="255" />

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000003}"
               Name="CEP_Badge_BadgeKey"    DisplayName="Badge Key"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="100" />

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000004}"
               Name="CEP_Badge_BadgeType"   DisplayName="Badge Type"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown">
          <CHOICES>
            <CHOICE>FirstSteps</CHOICE>
            <CHOICE>CrossAppExplorer</CHOICE>
            <CHOICE>WeeklyWarrior</CHOICE>
            <CHOICE>MonthlyMaster</CHOICE>
            <CHOICE>ConsistencyKing</CHOICE>
          </CHOICES>
        </Field>

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000005}"
               Name="CEP_Badge_EarnedDate"  DisplayName="Earned Date"
               Type="DateTime"              Group="CEP Columns"
               Format="DateTime" />

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000006}"
               Name="CEP_Badge_Description" DisplayName="Description"
               Type="Note"                  Group="CEP Columns"
               NumLines="3"                 RichText="FALSE" />

        <Field ID="{A1B2C3D4-0004-0004-0004-000000000007}"
               Name="CEP_Badge_MonthKey"    DisplayName="Month Key"
               Type="Text"                  Group="CEP Columns"
               MaxLength="10" />

        <!-- ── CEP_Config (key-value with category) ─────────── -->
        <Field ID="{A1B2C3D4-0005-0005-0005-000000000001}"
               Name="CEP_Cfg_Value"          DisplayName="Value"
               Type="Text"                  Group="CEP Columns"
               MaxLength="255" />

        <Field ID="{A1B2C3D4-0005-0005-0005-000000000011}"
               Name="CEP_Cfg_Category"       DisplayName="Category"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown"            Indexed="TRUE">
          <CHOICES>
            <CHOICE>sync</CHOICE>
            <CHOICE>scoring</CHOICE>
            <CHOICE>general</CHOICE>
            <CHOICE>badges</CHOICE>
          </CHOICES>
        </Field>

        <!-- ── CEP_SyncState ───────────────────────────────────── -->
        <Field ID="{A1B2C3D4-0006-0006-0006-000000000001}"
               Name="CEP_Sync_LastSuccessfulRunUtc" DisplayName="Last Successful Run (UTC)"
               Type="DateTime"              Group="CEP Columns"
               Format="DateTime" />

        <Field ID="{A1B2C3D4-0006-0006-0006-000000000002}"
               Name="CEP_Sync_LastRunStatus" DisplayName="Last Run Status"
               Type="Choice"                Group="CEP Columns"
               Format="Dropdown">
          <CHOICES>
            <CHOICE>Success</CHOICE>
            <CHOICE>Failure</CHOICE>
            <CHOICE>Running</CHOICE>
          </CHOICES>
        </Field>

        <Field ID="{A1B2C3D4-0006-0006-0006-000000000003}"
               Name="CEP_Sync_LastRunCorrelationId" DisplayName="Last Run Correlation Id"
               Type="Text"                  Group="CEP Columns"
               MaxLength="100" />

        <Field ID="{A1B2C3D4-0006-0006-0006-000000000004}"
               Name="CEP_Sync_LastRunSummary" DisplayName="Last Run Summary"
               Type="Note"                  Group="CEP Columns"
               NumLines="6"                 RichText="FALSE" />

        <Field ID="{A1B2C3D4-0006-0006-0006-000000000005}"
               Name="CEP_Sync_UsersProcessed" DisplayName="Users Processed"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

        <Field ID="{A1B2C3D4-0006-0006-0006-000000000006}"
               Name="CEP_Sync_PromptsIngested" DisplayName="Prompts Ingested"
               Type="Number"                Group="CEP Columns"
               Decimals="0"                 Min="0" />

      </pnp:SiteFields>

      <!-- ═══════════════════════════════════════════════════════
           LISTS
           ═══════════════════════════════════════════════════════ -->
      <pnp:Lists>

        <!-- ── 1. CEP_Users ───────────────────────────────────── -->
        <pnp:ListInstance
          Title="CEP_Users"
          Url="Lists/CEP_Users"
          TemplateType="100"
          Description="Copilot Engagement Program – enrolled users">
          <pnp:ContentTypeBindings>
            <pnp:ContentTypeBinding ContentTypeID="0x01" Default="true" />
          </pnp:ContentTypeBindings>
          <pnp:FieldRefs>
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000001}" Name="CEP_UserEmail"         DisplayName="User Email"             Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000002}" Name="CEP_UserPrincipalName" DisplayName="User Principal Name"    Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000003}" Name="CEP_AadUserId"         DisplayName="AAD User Id"            Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000004}" Name="CEP_Department"        DisplayName="Department" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000005}" Name="CEP_Team"              DisplayName="Team" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000006}" Name="CEP_EnrollmentDate"    DisplayName="Enrollment Date" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000007}" Name="CEP_CurrentLevel"      DisplayName="Current Level" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000008}" Name="CEP_TotalPoints"       DisplayName="Total Points" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000009}" Name="CEP_MonthlyPoints"     DisplayName="Monthly Points" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000010}" Name="CEP_IsActive"          DisplayName="Is Active" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000011}" Name="CEP_LastActivityDate"  DisplayName="Last Activity Date" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000012}" Name="CEP_IsEngagementNudgesEnabled" DisplayName="Engagement Nudges Enabled" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000013}" Name="CEP_LastSyncWatermarkUtc" DisplayName="Last Sync Watermark (UTC)" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000014}" Name="CEP_LastNudgeSentUtc"  DisplayName="Last Nudge Sent (UTC)" />
            <pnp:FieldRef ID="{A1B2C3D4-0001-0001-0001-000000000015}" Name="CEP_LastLeaderboardNotifiedMonth" DisplayName="Last Leaderboard Notified Month" />
          </pnp:FieldRefs>
          <pnp:Views>
            <View Name="All Users" DisplayName="All Users" DefaultView="TRUE" MobileView="TRUE" MobileDefaultView="TRUE">
              <Query>
                <OrderBy><FieldRef Name="CEP_MonthlyPoints" Ascending="FALSE"/></OrderBy>
              </Query>
              <ViewFields>
                <FieldRef Name="LinkTitle" />
                <FieldRef Name="CEP_UserEmail" />
                <FieldRef Name="CEP_Department" />
                <FieldRef Name="CEP_Team" />
                <FieldRef Name="CEP_CurrentLevel" />
                <FieldRef Name="CEP_TotalPoints" />
                <FieldRef Name="CEP_MonthlyPoints" />
                <FieldRef Name="CEP_IsActive" />
                <FieldRef Name="CEP_EnrollmentDate" />
                <FieldRef Name="CEP_LastActivityDate" />
              </ViewFields>
              <RowLimit Paged="TRUE">50</RowLimit>
            </View>
            <View Name="Active Users" DisplayName="Active Users">
              <Query>
                <Where><Eq><FieldRef Name="CEP_IsActive"/><Value Type="Boolean">1</Value></Eq></Where>
                <OrderBy><FieldRef Name="CEP_MonthlyPoints" Ascending="FALSE"/></OrderBy>
              </Query>
              <ViewFields>
                <FieldRef Name="LinkTitle" />
                <FieldRef Name="CEP_UserEmail" />
                <FieldRef Name="CEP_AadUserId" />
                <FieldRef Name="CEP_Department" />
                <FieldRef Name="CEP_Team" />
                <FieldRef Name="CEP_CurrentLevel" />
                <FieldRef Name="CEP_TotalPoints" />
                <FieldRef Name="CEP_MonthlyPoints" />
                <FieldRef Name="CEP_LastActivityDate" />
                <FieldRef Name="CEP_LastSyncWatermarkUtc" />
              </ViewFields>
              <RowLimit Paged="TRUE">100</RowLimit>
            </View>
          </pnp:Views>
        </pnp:ListInstance>

        <!-- ── 2. CEP_ActivityLog ─────────────────────────────── -->
        <pnp:ListInstance
          Title="CEP_ActivityLog"
          Url="Lists/CEP_ActivityLog"
          TemplateType="100"
          Description="Copilot Engagement Program – daily usage aggregates per user per app">
          <pnp:ContentTypeBindings>
            <pnp:ContentTypeBinding ContentTypeID="0x01" Default="true" />
          </pnp:ContentTypeBindings>
          <pnp:FieldRefs>
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000001}" Name="CEP_Log_AadUserId"    DisplayName="AAD User Id"   Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000002}" Name="CEP_Log_UserEmail"    DisplayName="User Email" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000003}" Name="CEP_Log_UsageDate"    DisplayName="Usage Date"    Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000004}" Name="CEP_Log_AppKey"       DisplayName="App"           Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000005}" Name="CEP_Log_PromptCount"  DisplayName="Prompt Count" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000006}" Name="CEP_Log_PointsEarned" DisplayName="Points Earned" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000007}" Name="CEP_Log_MonthKey"     DisplayName="Month Key"     Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000008}" Name="CEP_Log_IsWin"        DisplayName="Is Win" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000009}" Name="CEP_Log_WinNote"      DisplayName="Win Note" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000010}" Name="CEP_Log_IsShared"     DisplayName="Is Shared" />
            <pnp:FieldRef ID="{A1B2C3D4-0002-0002-0002-000000000011}" Name="CEP_Log_WinAppKey"    DisplayName="Win App Key" />
          </pnp:FieldRefs>
          <pnp:Views>
            <View Name="All Activity" DisplayName="All Activity" DefaultView="TRUE">
              <Query>
                <OrderBy><FieldRef Name="CEP_Log_UsageDate" Ascending="FALSE"/></OrderBy>
              </Query>
              <ViewFields>
                <FieldRef Name="LinkTitle" />
                <FieldRef Name="CEP_Log_AadUserId" />
                <FieldRef Name="CEP_Log_UserEmail" />
                <FieldRef Name="CEP_Log_UsageDate" />
                <FieldRef Name="CEP_Log_AppKey" />
                <FieldRef Name="CEP_Log_PromptCount" />
                <FieldRef Name="CEP_Log_PointsEarned" />
                <FieldRef Name="CEP_Log_MonthKey" />
                <FieldRef Name="CEP_Log_IsWin" />
                <FieldRef Name="CEP_Log_WinNote" />
                <FieldRef Name="CEP_Log_IsShared" />
                <FieldRef Name="CEP_Log_WinAppKey" />
              </ViewFields>
              <RowLimit Paged="TRUE">100</RowLimit>
            </View>
          </pnp:Views>
        </pnp:ListInstance>

        <!-- ── 3. CEP_Leaderboard ─────────────────────────────── -->
        <pnp:ListInstance
          Title="CEP_Leaderboard"
          Url="Lists/CEP_Leaderboard"
          TemplateType="100"
          Description="Copilot Engagement Program – materialized monthly leaderboard">
          <pnp:ContentTypeBindings>
            <pnp:ContentTypeBinding ContentTypeID="0x01" Default="true" />
          </pnp:ContentTypeBindings>
          <pnp:FieldRefs>
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000001}" Name="CEP_LB_UserEmail"     DisplayName="User Email" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000002}" Name="CEP_LB_DisplayName"   DisplayName="Display Name" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000003}" Name="CEP_LB_Department"    DisplayName="Department" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000004}" Name="CEP_LB_Team"          DisplayName="Team" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000005}" Name="CEP_LB_AadUserId"     DisplayName="AAD User Id" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000006}" Name="CEP_LB_MonthlyPoints" DisplayName="Monthly Points" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000007}" Name="CEP_LB_Rank"          DisplayName="Rank" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000008}" Name="CEP_LB_Level"         DisplayName="Level" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000009}" Name="CEP_LB_Scope"         DisplayName="Scope"         Required="true" />
            <pnp:FieldRef ID="{A1B2C3D4-0003-0003-0003-000000000010}" Name="CEP_LB_MonthKey"      DisplayName="Month Key"     Required="true" />
          </pnp:FieldRefs>
          <pnp:Views>
            <View Name="Current Month Global" DisplayName="Current Month Global" DefaultView="TRUE">
              <Query>
                <Where>
                  <Eq><FieldRef Name="CEP_LB_Scope"/><Value Type="Choice">Global</Value></Eq>
                </Where>
                <OrderBy><FieldRef Name="CEP_LB_Rank" Ascending="TRUE"/></OrderBy>
              </Query>
              <ViewFields>
                <FieldRef Name="CEP_LB_Rank" />
                <FieldRef Name="CEP_LB_DisplayName" />
                <FieldRef Name="CEP_LB_Department" />
                <FieldRef Name="CEP_LB_Team" />
                <FieldRef Name="CEP_LB_MonthlyPoints" />
                <FieldRef Name="CEP_LB_Level" />
                <FieldRef Name="CEP_LB_Scope" />
                <FieldRef Name="CEP_LB_MonthKey" />

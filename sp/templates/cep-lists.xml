        <Field ID="{A1B2C3D4-0001-0001-0001-000000000004}"
               Name="CEP_Department"        DisplayName="Department"
               Type="Text"                  Group="CEP Columns"
               Indexed="TRUE"               MaxLength="255" />

        <Field ID="{A1B2C3D4-0001-0001-0001-000000000005}"

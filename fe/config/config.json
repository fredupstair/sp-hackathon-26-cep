{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "cep-bar-application-customizer": {
      "components": [
        {
          "entrypoint": "./lib/extensions/cepBar/CepBarApplicationCustomizer.js",
          "manifest": "./src/extensions/cepBar/CepBarApplicationCustomizer.manifest.json"
        }
      ]
    },
    "cep-leaderboard-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/cepLeaderboard/CepLeaderboardWebPart.js",
          "manifest": "./src/webparts/cepLeaderboard/CepLeaderboardWebPart.manifest.json"
        }
      ]
    },
    "cep-welcome-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/cepWelcome/CepWelcomeWebPart.js",
          "manifest": "./src/webparts/cepWelcome/CepWelcomeWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "CepBarApplicationCustomizerStrings": "lib/extensions/cepBar/loc/{locale}.js",
    "CepLeaderboardWebPartStrings": "lib/webparts/cepLeaderboard/loc/{locale}.js",
    "CepWelcomeWebPartStrings": "lib/webparts/cepWelcome/loc/{locale}.js"
  }
}

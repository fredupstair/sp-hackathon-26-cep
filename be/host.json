{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information",
      "CepFunctions": "Debug"
    }
  },
  "extensions": {
    "queues": {
      "maxPollingInterval": "00:00:10",
      "visibilityTimeout": "00:05:00",
      "batchSize": 1,
      "maxDequeueCount": 5
    }
  },
  "functionTimeout": "00:10:00"
}

{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "TenantId": "<your-tenant-id>",
    "ClientId": "<app-registration-client-id>",
    "ClientSecret": "<app-registration-client-secret>",

    "SpSiteId": "<sharepoint-site-id-guid>",
    "SpSiteUrl": "https://<tenant>.sharepoint.com/sites/<site>",

    "ListId_Users": "<cep-users-list-id-guid>",
    "ListId_ActivityLog": "<cep-activitylog-list-id-guid>",
    "ListId_Leaderboard": "<cep-leaderboard-list-id-guid>",
    "ListId_Badges": "<cep-badges-list-id-guid>",
    "ListId_Config": "<cep-config-list-id-guid>",
    "ListId_SyncState": "<cep-syncstate-list-id-guid>",

    "IngestQueueName": "cep-ingest",
    "TeamsAppId": "<teams-app-id-for-notifications>",

    "APPLICATIONINSIGHTS_CONNECTION_STRING": "<app-insights-connection-string>"
  }
}
